/dist/
/build/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go build artifacts
*.out
*.test
*.prof

# Temporary build files
/tmp/
/temp/

# Air live reload temporary files
tmp/
.air/

# =============================================================================
