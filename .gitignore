# =============================================================================
# SECURITY - Sensitive Files (NEVER COMMIT THESE!)
# =============================================================================

# Environment variables with secrets
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
!.env.example

# Database configuration with credentials
dbconfig.yml
database.yml

# SSL/TLS certificates and keys
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks

# API keys and secrets
secrets.json
credentials.json
service-account*.json
*-credentials.json

# SSH keys
id_rsa
id_rsa.pub
*.ppk

